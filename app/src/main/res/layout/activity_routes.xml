<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ui_main_bg">

    <!-- HEADER SECTION -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="28dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PARADA"
                android:textColor="@color/ui_orange"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfileHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                app:cardBackgroundColor="@color/ui_card_surface"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ui_divider">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        app:tint="@color/ui_orange"/>

                    <TextView
                        android:id="@+id/tvUsernameHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Guest"
                        android:textColor="@color/ui_text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <TextView
            android:id="@+id/tvWelcomeUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hello, Guest"
            android:textColor="@color/ui_text_secondary"
            android:textSize="16sp"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Where you want to go?"
            android:textColor="@color/ui_text_primary"
            android:textSize="32sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/bottom_navigation"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- PLAN YOUR TRIP CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/ui_card_surface"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ui_divider">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plan Your Trip"
                        android:textColor="@color/ui_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="24dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/dot_start"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="22dp"
                            android:background="@drawable/back_circle_bg"
                            android:backgroundTint="@color/ui_orange" />

                        <View
                            android:id="@+id/dot_end"
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginTop="90dp"
                            android:background="@drawable/back_circle_bg"
                            android:backgroundTint="@color/ui_orange" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="60dp"
                            android:layout_below="@id/dot_start"
                            android:layout_alignStart="@id/dot_start"
                            android:layout_marginStart="4.5dp"
                            android:background="@color/ui_divider" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="28dp"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/etOrigin"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:background="@drawable/ui_input_bg"
                                android:hint="From: Select Location"
                                android:paddingStart="16dp"
                                android:textColor="@color/ui_text_primary"
                                android:textColorHint="@color/ui_text_secondary"
                                android:textSize="14sp"
                                android:focusable="false"
                                android:clickable="true" />

                            <EditText
                                android:id="@+id/etDestination"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/ui_input_bg"
                                android:hint="To: Select Destination"
                                android:paddingStart="16dp"
                                android:textColor="@color/ui_text_primary"
                                android:textColorHint="@color/ui_text_secondary"
                                android:textSize="14sp"
                                android:focusable="false"
                                android:clickable="true" />

                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Select Vehicle Type"
                android:textColor="@color/ui_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- VEHICLE TYPE SELECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- Tricycle Option -->
                <LinearLayout
                    android:id="@+id/btnTricycle"
                    android:layout_width="0dp"
                    android:layout_height="95dp"
                    android:layout_weight="1"
                    android:background="@drawable/ui_input_bg"
                    android:backgroundTint="@color/ui_orange"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/img_10" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tricycle"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Jeepney Option -->
                <LinearLayout
                    android:id="@+id/btnJeepney"
                    android:layout_width="0dp"
                    android:layout_height="95dp"
                    android:layout_weight="1"
                    android:background="@drawable/ui_input_bg"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/img_9" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Jeepney"
                        android:textColor="@color/ui_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- PASSENGER SELECTION -->
            <LinearLayout
                android:id="@+id/layoutPassengerSelection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Number of Passengers"
                    android:textColor="@color/ui_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPass1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="1-2 "
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/ui_orange"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPass3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="3"
                        android:textAllCaps="false"
                        android:textColor="@color/ui_text_secondary"
                        android:backgroundTint="@color/ui_input_bg"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- RESULT CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/ui_card_surface"
                app:strokeWidth="1dp"
                app:strokeColor="@color/ui_orange"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvResultDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance: 0 km"
                        android:textColor="@color/ui_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvResultFare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Fare: ₱0.00"
                        android:textColor="@color/ui_orange"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="40dp"
                android:text="Calculate fare"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="@color/ui_orange"
                android:textColor="@color/white"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:background="@color/ui_card_surface"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</RelativeLayout>
